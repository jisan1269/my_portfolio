rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Site settings (photo, CV link, CP stats) — public read, admin write
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Public content collections — anyone can read, only the signed-in
    // admin (you, via admin.html) can add/edit/delete
    match /projects/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /research/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /recognition/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /certifications/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contact form messages — anyone can send one, only admin can read them
    match /messages/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
